<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Chernobyl_Relay_Chat.LanguagePrompt"
        Title="Select Language"
        Width="300" Height="220"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                Spacing="12" Margin="24">
        <TextBlock TextAlignment="Center" TextWrapping="Wrap">
            Select your language / Выберите язык
        </TextBlock>
        <Button Name="buttonEnglish"  HorizontalAlignment="Stretch">English</Button>
        <Button Name="buttonSlavik"   HorizontalAlignment="Stretch">Українська</Button>
        <Button Name="buttonRussian"  HorizontalAlignment="Stretch">Русский</Button>
    </StackPanel>
</Window>
